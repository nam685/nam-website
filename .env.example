DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
POSTGRES_PASSWORD=change-me-to-a-random-string
DATABASE_URL=postgres://postgres:change-me-to-a-random-string@localhost:5432/nam_website
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_SECRET=change-me-to-a-random-string
CSRF_TRUSTED_ORIGINS=http://localhost:3001

# Frontend (optional — only needed when not behind Caddy proxy)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# OAuth credentials (optional — only needed for 'make sync' live API calls)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Market data (bets page)
# ALPHA_VANTAGE_API_KEY=your-free-key-from-alphavantage.co

# Last.fm API key for music-graph similarity edges (optional; graph still builds without it)
LASTFM_API_KEY=

# AoE2 (Empires tab) — owner's relic profile id + in-game name
AOE2_PROFILE_ID=14697894
AOE2_IGN=nom
# AOE2_CLAUDE_BIN=  # prod: set to absolute path e.g. /home/nam/.local/bin/claude
# AOE2_COACH_MODEL=sonnet  # model alias passed to claude --model (default: sonnet)
